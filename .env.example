# Optional production persistence. When omitted in development, applications
# are written to .data/applications.ndjson.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase credentials for the /admin console (safe to expose; access is
# gated by Supabase Auth + row-level security).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional bot protection. Both values are required to enable Turnstile.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional notification integration.
APPLICATION_NOTIFICATION_WEBHOOK_URL=
